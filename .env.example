# Copy to .env (or export in your shell) to enable LLM triage
ANTHROPIC_API_KEY=sk-ant-...

# Splunk integration (--source splunk): pulls Windows/AD Security events
# 4624/4625 via the REST API. Splunk Cloud host looks like
# mystack.splunkcloud.com; self-hosted is your server IP/hostname.
SPLUNK_HOST=mystack.splunkcloud.com
SPLUNK_PORT=8089
# Preferred: an authentication token (Settings > Tokens in Splunk Web)
SPLUNK_TOKEN=eyJr...
# Or basic auth instead of a token:
# SPLUNK_USERNAME=admin
# SPLUNK_PASSWORD=...
SPLUNK_INDEX=wineventlog
# Set to false for self-signed certs on a lab instance
SPLUNK_VERIFY_SSL=true
